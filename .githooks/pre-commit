#!/usr/bin/env bash
# Pre-commit gate — runs only the checks relevant to what's staged. Installed by
# ./install-hooks.sh (sets core.hooksPath). Git runs it from the repo root.
#
# COMMIT THIS FILE WITH MODE 755. Git SILENTLY SKIPS a non-executable
# core.hooksPath hook — the gate looks installed but never fires.
# Verify: `git ls-files -s .githooks` → mode must read 100755.
set -euo pipefail

staged="$(git diff --cached --name-only --diff-filter=ACMR)"
[ -n "$staged" ] || exit 0

run_front=0
run_rust=0
while IFS= read -r f; do
	case "$f" in
	frontend/*) run_front=1 ;;
	esac
	case "$f" in
	backend/* | Cargo.toml | Cargo.lock) run_rust=1 ;;
	esac
done <<<"$staged"

if [ "$run_front" = 1 ]; then
	echo "pre-commit: frontend (lint + format)"
	# Vendored yarn (no corepack), invoked via node from the frontend dir.
	(cd frontend && node .yarn/releases/yarn-*.cjs lint && node .yarn/releases/yarn-*.cjs format)
fi

if [ "$run_rust" = 1 ]; then
	echo "pre-commit: rust (clippy + fmt, whole workspace)"
	cargo clippy --workspace --all-targets -- -D warnings
	cargo fmt --all -- --check
fi

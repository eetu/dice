{
  "name": "dice-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "dev:host": "DEV_HOST=1 vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "e2e:install": "playwright install chromium",
    "validate": "yarn typecheck && yarn lint && yarn format"
  },
  "dependencies": {
    "@anarkisti/igyb": "^0.3.0",
    "@fontsource/inter": "^5",
    "@fontsource/space-grotesk": "^5",
    "@glowbox/nixie": "^1.1.0",
    "@lucide/svelte": "^1.22.0",
    "cannon-es": "^0.20.0",
    "qrcode": "^1.5.4",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@anarkisti/eslint-config": "^1.1.0",
    "@playwright/test": "^1.61.1",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.69.2",
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@types/node": "^26",
    "@types/qrcode": "^1.5.5",
    "@types/three": "^0.185.1",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitest/browser-playwright": "^4.1.10",
    "eslint": "^10.4.0",
    "playwright": "^1.61.1",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^4.0.1",
    "svelte": "^5.56.1",
    "svelte-check": "^4.4.6",
    "typescript": "^6.0.2",
    "vite": "^8.1.4",
    "vite-plugin-qrcode": "^0.4.1",
    "vitest": "^4.1.10",
    "vitest-browser-svelte": "^2.2.1"
  },
  "packageManager": "yarn@4.16.0"
}
